{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "title",
    "type",
    "authors",
    "publisher",
    "series",
    "publication_date",
    "doi_suffix",
    "url",
    "language",
    "keywords",
    "abstract",
    "content_hash"
  ],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["paper", "dataset", "software", "book", "working-paper"]
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "orcid"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "orcid": { "type": "string", "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{4}$" }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },
    "publisher": { "type": "string", "minLength": 1 },
    "series": { "type": "string", "minLength": 1 },
    "publication_date": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "doi_suffix": {
      "type": "string",
      "pattern": "^uvlm\\.(paper|dataset|software)\\.[a-z0-9-]+\\.v[0-9]+$"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "language": { "type": "string", "pattern": "^[a-z]{2}$" },
    "keywords": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "abstract": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^v[0-9]+$" },
    "license": { "type": "string" },
    "previous_doi": { "type": "string" },
    "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "doi"],
        "properties": {
          "type": { "type": "string" },
          "doi": { "type": "string", "pattern": "^10\\.[0-9]{4,9}/[-._;()/:A-Z0-9a-z]+$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
